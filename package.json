{
  "name": "magick-book",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_ENV=production next build",
    "start": "next start",
    "seed": "node --env-file=.env.local --import tsx src/scripts/seed.ts",
    "seed:force": "node --env-file=.env.local --import tsx src/scripts/seed.ts --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.14.0",
    "firebase-admin": "^13.10.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "mongoose": "^9.6.3",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^12.0.2",
    "@tailwindcss/postcss": "^4",
